# Bling OAuth
# BLING_CLIENT_SECRET tambem eh usado para validar a assinatura HMAC dos webhooks (X-Bling-Signature-256).
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
PUBLIC_BASE_URL=http://localhost:3002
BLING_REDIRECT_URI=http://localhost:3002/auth/callback

# Database
POSTGRES_USER=bling
POSTGRES_PASSWORD=blingpass
POSTGRES_DB=blingdb
POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=postgres://bling:blingpass@localhost:5432/blingdb

# Published ports
BLING_SYNC_BIND=127.0.0.1
BLING_SYNC_PORT=3002
METABASE_BIND=127.0.0.1
METABASE_PORT=3001

# Runtime
TZ=America/Sao_Paulo
RUN_WORKER=true
RUN_DAILY_RECONCILIATION=true
# Empty means full initial backfill. Set YYYY-MM-DD to limit the initial load.
BACKFILL_START_DATE=
BACKFILL_ENTITIES=produtos,pedidos,contatos,notas_fiscais,contas_receber,contas_pagar
RECONCILIATION_ENTITIES=produtos,pedidos,contatos,notas_fiscais,contas_receber,contas_pagar
RECONCILIATION_WINDOW_DAYS=7
DAILY_RECONCILIATION_HOUR=3
WORKER_INTERVAL_MS=10000
WORKER_BATCH_SIZE=25
BLING_REQUEST_DELAY_MS=350
LOG_FILE=/app/logs/bling-sync.log

# Override only if Bling changes endpoint paths
BLING_PEDIDOS_PATH=/pedidos/vendas
BLING_PRODUTOS_PATH=/produtos
BLING_CONTATOS_PATH=/contatos
BLING_NOTAS_FISCAIS_PATH=/nfe
BLING_CONTAS_RECEBER_PATH=/contas/receber
BLING_CONTAS_PAGAR_PATH=/contas/pagar
